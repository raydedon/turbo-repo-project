{
  "$schema": "https://turborepo.dev/microfrontends/schema.json",
  "applications": {
    "turbo-repo-project-blogs": {
      "packageName": "blogs",
      "development": {
        "local": {
          "port": 3000
        },
        "fallback": "turbo-repo-project-blogs.vercel.app"
      }
    },
    "turbo-repo-project-users": {
      "packageName": "users",
      "development": {
        "local": {
          "port": 3001
        }
      },
      "routing": [
        {
          "paths": ["/users", "/users/:path*"]
        }
      ]
    }
  },
  "options": {
    "localProxyPort": 3024
  }
}
