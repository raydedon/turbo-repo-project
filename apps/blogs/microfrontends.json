{
  "$schema": "https://turborepo.dev/microfrontends/schema.json",
  "applications": {
    "blogs": {
      "development": {
        "local": {
          "port": 3000
        }
      }
    },
    "users": {
      "routing": [
        {
          "paths": ["/users", "/users/:path*"]
        }
      ],
      "development": {
        "local": {
          "port": 3001
        }
      }
    }
  },
  "options": {
    "localProxyPort": 3024
  }
}
