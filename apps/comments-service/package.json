  },
  "dependencies": {
    "@apollo/subgraph": "^2.9.0",
    "@nestjs/apollo": "^12.2.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dataloader": "^2.2.2",
    "dotenv": "^16.0.3",
    "graphql": "^16.9.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@apollo/gateway": "^2.13.3",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "prisma": "^7.7.0",
    "ts-morph": "^24.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.2"
