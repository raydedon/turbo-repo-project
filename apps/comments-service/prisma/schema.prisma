generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Comment {
  id        Int      @id @default(autoincrement())
  // postId/userId are logical references — NOT foreign keys (cross-service)
  postId    Int
  userId    Int
  body      String
  createdAt DateTime @default(now())
}
